# ===================================
# NexusTradeAI Configuration
# ===================================
# Copy this file to .env and add your actual values.
#
# NOTE: Broker API keys (Alpaca, OANDA, Kraken, etc.) are stored ENCRYPTED
# per-user in the PostgreSQL database — NOT in env vars. Users configure
# them through Settings → Brokers in the dashboard.
# The env vars below are for infrastructure config only.

# Application settings
APP_ENV=development
DEBUG=True
LOG_LEVEL=INFO

# ===================================
# Broker Credentials (LEGACY / FALLBACK ONLY)
# ===================================
# These are NO LONGER the primary way to configure broker keys.
# Users save their keys via the dashboard (encrypted in DB per-user).
# Only set these if you need a system-wide fallback (e.g. single-tenant dev setup).
# ALPACA_API_KEY=
# ALPACA_SECRET_KEY=

# Optional: Additional data providers
# POLYGON_API_KEY=
# FINNHUB_API_KEY=
# ALPHA_VANTAGE_API_KEY=

# ===================================
# Trading Configuration
# ===================================
# Symbols to trade (comma-separated) - Comment out to use full 132-symbol list from server
# TRADING_SYMBOLS=AAPL,GOOGL,MSFT,TSLA,NVDA

# Risk management
RISK_PER_TRADE=0.01          # 1% risk per trade (REDUCED for safety)
MAX_DAILY_LOSS=-1000         # Maximum $1K daily loss (REDUCED for safety)
MAX_POSITION_SIZE=2000       # Maximum $2K per position (REDUCED for safety)

# Trading strategies (comma-separated)
# Options: trendFollowing, meanReversion, momentum, aiSignals, arbitrage, neuralNet
ENABLED_STRATEGIES=trendFollowing

# AI features
AI_ENABLED=true              # Enable AI predictions

# IMPORTANT: Keep false for paper trading
REAL_TRADING_ENABLED=false   # Set to true ONLY for live trading with real money

# ===================================
# Service Ports
# ===================================
TRADING_PORT=3002            # Trading engine server
MARKET_DATA_PORT=3001        # Market data service
RISK_MANAGER_PORT=3004       # Risk management service
AI_SERVICE_PORT=5001         # AI prediction service (5001 for macOS, avoid 5000)

# ===================================
# Database (PostgreSQL)
# ===================================
# Railway injects DATABASE_URL automatically.
# For local dev:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nexustradeai

# ===================================
# Authentication & Credential Encryption
# ===================================
# JWT_SECRET: used for user login tokens. MUST be set in production.
JWT_SECRET=change-me-to-a-random-64-char-string
JWT_REFRESH_SECRET=change-me-to-another-random-string

# CREDENTIAL_ENCRYPTION_KEY: 32-byte hex key for AES-256-GCM encryption
# of user broker API keys stored in the database.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If unset, the system derives a key from JWT_SECRET (acceptable but less secure).
# CREDENTIAL_ENCRYPTION_KEY=

# NEXUS_API_SECRET: shared secret for legacy non-credential config endpoints.
# New credential endpoints use JWT auth instead.
# NEXUS_API_SECRET=

# ===================================
# Feature Store & MLflow
# ===================================
FEATURE_STORE_PATH=./data/feature_store
MLFLOW_TRACKING_URI=./mlruns
MLFLOW_S3_ENDPOINT_URL=http://localhost:9000
AWS_ACCESS_KEY_ID=minio
AWS_SECRET_ACCESS_KEY=minio123



# Redis Cache
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Memory Management
MAX_HEAP_MB=400
MEMORY_WARNING_THRESHOLD=0.75
MEMORY_CRITICAL_THRESHOLD=0.90
MEMORY_FORCE_GC_THRESHOLD=0.85
MEMORY_CHECK_INTERVAL_MS=10000
MEMORY_CLEANUP_INTERVAL_MS=60000

# Monitoring & Metrics
METRICS_PORT=9091
PROMETHEUS_ENABLED=true
PROMETHEUS_HOST=localhost
PROMETHEUS_PORT=9090
GRAFANA_ENABLED=true
GRAFANA_PORT=3030
GRAFANA_PASSWORD=admin

# Health Checks
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL_MS=30000

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
LOG_FILE_PATH=./logs
LOG_MAX_SIZE=10m
LOG_MAX_FILES=7
LOG_ROTATE=true

# Docker Configuration
COMPOSE_PROJECT_NAME=nexustradeai
DOCKER_RESTART_POLICY=unless-stopped

# Production Settings
NODE_ENV=production
TZ=America/New_York

# ===================================
# SMS Alert Configuration
# ===================================
# Get Twilio credentials from: https://www.twilio.com/console
SMS_ALERTS_ENABLED=false         # Set to true to enable SMS alerts
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890  # Your Twilio phone number (with +1)
ALERT_PHONE_NUMBER=+1234567890   # Your personal phone number (with +1)

# ===================================
# Telegram Alert Configuration (FREE!)
# ===================================
# Get bot token from: @BotFather on Telegram (completely free, unlimited messages!)
# Get chat ID from: @userinfobot on Telegram
TELEGRAM_ALERTS_ENABLED=false             # Set to true to enable Telegram alerts
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here  # From @BotFather
TELEGRAM_CHAT_ID=your_telegram_chat_id_here      # Your chat ID from @userinfobot

# ===================================
# Crypto Trading Configuration (24/7)
# ===================================
# ⚠️ WARNING: Crypto trading is HIGH RISK - use testnet first!
# Binance Testnet: https://testnet.binance.vision/
# Binance Live: https://www.binance.com/en/register

CRYPTO_PORT=3006                          # Crypto bot server port

# Crypto Exchange Selection (binance, coinbase, kraken)
CRYPTO_EXCHANGE=kraken

# Crypto API credentials — configure via dashboard Settings → Brokers
# These env vars are FALLBACK only (system uses per-user DB storage):
# CRYPTO_API_KEY=
# CRYPTO_API_SECRET=
CRYPTO_TESTNET=true                       # IMPORTANT: Set to true for testnet (paper trading)

# Crypto Risk Management (Conservative)
CRYPTO_MAX_POSITIONS=2                    # Max 2 positions (high volatility)
CRYPTO_MAX_TRADES_PER_DAY=10              # Daily trade limit
CRYPTO_RISK_PER_TRADE=0.02                # 2% risk per trade
CRYPTO_BASE_POSITION_SIZE=500             # $500 per position
CRYPTO_MAX_POSITION_SIZE=2000             # Max $2000 per position

# Coinbase Pro: https://pro.coinbase.com/
# COINBASE_API_KEY=
# COINBASE_API_SECRET=

# Kraken: https://www.kraken.com/
# KRAKEN_API_KEY=
# KRAKEN_API_SECRET=
