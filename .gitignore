# Dashboard dist is always rebuilt by CI — never track in git
deploy/dashboard/dist/

# Android / mobile build artifacts
clients/mobile-app/android/
**/.gradle/

# Credential-bearing config files — never commit these
config/alpaca-config.json
config/*-credentials.json
config/*-config.json
services/broker-api/broker-configs.json
services/broker-api/*-config.json
services/trading/.env.*
**/*.env.backup
**/*.env.bak

