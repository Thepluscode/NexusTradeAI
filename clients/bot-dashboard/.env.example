# ── NexusTradeAI Frontend Environment Variables ──────────────────────────────
# Copy to .env.local for local overrides, or set in Railway dashboard for production.
# All variables must be prefixed with VITE_ to be exposed to the browser bundle.

# Bot backend URLs — set these to your Railway service URLs in production
# Leave blank to use localhost defaults (for local development)
VITE_STOCK_BOT_URL=
VITE_FOREX_BOT_URL=
VITE_CRYPTO_BOT_URL=
VITE_MARKET_DATA_URL=
VITE_AI_SERVICE_URL=

# Trading mode flag (shown in UI — does not enable real trading by itself)
VITE_REAL_TRADING_ENABLED=false
